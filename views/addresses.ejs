<!DOCTYPE html>
<html lang="ru">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Мои адреса | PLAZA</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/main.css">    
    <style>
        .addresses-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin: 40px 0 20px;
        }
        
        .addresses-header h1 {
            font-size: 24px;
            font-weight: 700;
        }
        
        .btn-add {
            background: #000;
            color: #fff;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
        }
        
        .addresses-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }
        
        .address-card {
            background: #fff;
            border: 1px solid #eaeaea;
            border-radius: 16px;
            padding: 20px;
            position: relative;
        }
        
        .address-card.default {
            border-color: #000;
            border-width: 2px;
        }
        
        .address-badge {
            position: absolute;
            top: 20px;
            right: 20px;
            background: #000;
            color: #fff;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 10px;
            font-weight: 700;
        }
        
        .address-name {
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 15px;
            padding-right: 80px;
        }
        
        .address-details {
            font-size: 13px;
            color: #666;
            margin-bottom: 15px;
            line-height: 1.6;
        }
        
        .address-phone {
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 20px;
        }
        
        .address-actions {
            display: flex;
            gap: 10px;
            border-top: 1px solid #f0f0f0;
            padding-top: 15px;
        }
        
        .address-actions a,
        .address-actions button {
            text-decoration: none;
            font-size: 12px;
            font-weight: 600;
            padding: 5px 10px;
            border-radius: 4px;
            background: none;
            border: none;
            cursor: pointer;
        }
        
        .btn-edit {
            color: #666;
        }
        
        .btn-delete {
            color: #d63031;
        }
        
        .btn-default {
            color: #00b894;
            margin-left: auto;
        }
        
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background: #f8f8f8;
            border-radius: 16px;
            margin: 40px 0;
        }
        
        .empty-state p {
            font-size: 16px;
            color: #666;
            margin-bottom: 20px;
        }
        
        .back-link {
            display: inline-block;
            margin-bottom: 20px;
            color: #666;
            text-decoration: none;
            font-size: 13px;
        }
        
        .success-message {
            background: #e8f5e9;
            border: 1px solid #00b894;
            color: #00b894;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 20px;
        }
        
        .error-message {
            background: #fff0f0;
            border: 1px solid #d63031;
            color: #d63031;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Хедер -->
        <!-- Шапка сайта -->
<div class="header">
    <a href="/" class="logo">PLAZA</a>
    <div class="nav-links">
        <a href="/">Главная</a>
        <a href="/catalog">Кроссовки</a>
        <a href="/hunts">Охота</a>
        <a href="#">Бренды</a>
    </div>
    <div class="header-actions">
    <% if (user) { %>
        <a href="/cabinet">Профиль</a>
        <a href="/favorites">❤️ Избранное</a>
        <a href="/cart">🛒 Корзина</a>
        <a href="/logout">Выйти</a>
    <% } else { %>
        <a href="/login">Войти</a>
        <a href="/register">Регистрация</a>
    <% } %>
</div>
</div>
        
        <a href="/cabinet" class="back-link">← Назад в кабинет</a>
        
        <% if (success === 'added') { %>
            <div class="success-message">Адрес успешно добавлен!</div>
        <% } %>
        
        <% if (success === 'updated') { %>
            <div class="success-message">Адрес обновлен!</div>
        <% } %>
        
        <% if (success === 'deleted') { %>
            <div class="success-message">Адрес удален!</div>
        <% } %>
        
        <% if (error === '1') { %>
            <div class="error-message">Произошла ошибка</div>
        <% } %>
        
        <div class="addresses-header">
            <h1>Мои адреса доставки</h1>
            <a href="/addresses/new" class="btn-add">+ Новый адрес</a>
        </div>
        
        <% if (addresses && addresses.length > 0) { %>
            <div class="addresses-grid">
                <% addresses.forEach(addr => { %>
                    <div class="address-card <%= addr.is_default ? 'default' : '' %>">
                        <% if (addr.is_default) { %>
                            <span class="address-badge">ОСНОВНОЙ</span>
                        <% } %>
                        
                        <div class="address-name"><%= addr.name %></div>
                        <div class="address-details">
                            <%= addr.recipient %><br>
                            <%= addr.country %>, <%= addr.city %><br>
                            <%= addr.address %><br>
                            <%= addr.postal_code || '' %>
                        </div>
                        <div class="address-phone">📞 <%= addr.phone %></div>
                        
                        <div class="address-actions">
                            <a href="/addresses/<%= addr.id %>/edit" class="btn-edit">Редактировать</a>
                            <form method="POST" action="/addresses/<%= addr.id %>/delete" style="display: inline;">
                                <button type="submit" class="btn-delete" onclick="return confirm('Удалить адрес?')">Удалить</button>
                            </form>
                            <% if (!addr.is_default) { %>
                                <form method="POST" action="/addresses/<%= addr.id %>" style="display: inline; margin-left: auto;">
                                    <input type="hidden" name="name" value="<%= addr.name %>">
                                    <input type="hidden" name="recipient" value="<%= addr.recipient %>">
                                    <input type="hidden" name="phone" value="<%= addr.phone %>">
                                    <input type="hidden" name="country" value="<%= addr.country %>">
                                    <input type="hidden" name="city" value="<%= addr.city %>">
                                    <input type="hidden" name="address" value="<%= addr.address %>">
                                    <input type="hidden" name="postal_code" value="<%= addr.postal_code %>">
                                    <input type="hidden" name="is_default" value="1">
                                    <button type="submit" class="btn-default">Сделать основным</button>
                                </form>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <p>У вас пока нет сохраненных адресов</p>
                <a href="/addresses/new" class="btn-add">Добавить первый адрес</a>
            </div>
        <% } %>
        
        <!-- Подвал -->
        <div class="footer">
            <div class="footer-grid">
                <div class="footer-col">
                    <h4>PLAZA</h4>
                    <ul>
                        <li><a href="#">О нас</a></li>
                        <li><a href="#">Контакты</a></li>
                        <li><a href="#">Доставка</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>ПОКУПАТЕЛЯМ</h4>
                    <ul>
                        <li><a href="#">Как заказать</a></li>
                        <li><a href="#">Размерная сетка</a></li>
                        <li><a href="#">Возврат</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>БРЕНДЫ</h4>
                    <ul>
                        <li><a href="#">Nike</a></li>
                        <li><a href="#">Adidas</a></li>
                        <li><a href="#">Li-Ning</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>СВЯЗАТЬСЯ</h4>
                    <ul>
                        <li><a href="#">Telegram</a></li>
                        <li><a href="#">VK</a></li>
                        <li><a href="#">hello@plaza.ru</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                © 2024 PLAZA. Кроссовки со всего мира.
            </div>
        </div>
    </div>
    
    <script>
        const urlParams = new URLSearchParams(window.location.search);
        window.success = urlParams.get('success');
        window.error = urlParams.get('error');
    </script>
    <script src="/js/navigation.js" defer></script>
</body>
</html>