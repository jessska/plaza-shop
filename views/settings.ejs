<!DOCTYPE html>
<html lang="ru">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Настройки профиля | PLAZA</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/main.css">    
    <style>
        .settings-container {
            max-width: 600px;
            margin: 40px auto;
        }
        
        .settings-card {
            background: #fff;
            border: 1px solid #eaeaea;
            border-radius: 16px;
            padding: 30px;
            margin-bottom: 30px;
        }
        
        .settings-card h2 {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 25px;
            letter-spacing: -0.5px;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        
        .form-group label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            color: #666;
            margin-bottom: 8px;
            letter-spacing: 0.5px;
        }
        
        .form-group input,
        .form-group select {
            width: 100%;
            padding: 12px;
            border: 1px solid #eaeaea;
            border-radius: 8px;
            font-size: 14px;
            font-family: 'Inter', sans-serif;
        }
        
        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: #000;
        }
        
        .form-group input[readonly] {
            background: #f5f5f5;
            color: #999;
            cursor: not-allowed;
        }
        
        .checkbox-group {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 15px;
        }
        
        .checkbox-group input {
            width: auto;
        }
        
        .checkbox-group label {
            margin: 0;
            text-transform: none;
            color: #000;
            font-size: 14px;
        }
        
        .btn {
            background: #000;
            color: #fff;
            border: none;
            padding: 12px 30px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            cursor: pointer;
            width: 100%;
        }
        
        .btn:hover {
            background: #222;
        }
        
        .success-message {
            background: #e8f5e9;
            border: 1px solid #00b894;
            color: #00b894;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 13px;
        }
        
        .error-message {
            background: #fff0f0;
            border: 1px solid #d63031;
            color: #d63031;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 13px;
        }
        
        .back-link {
            display: inline-block;
            margin-bottom: 20px;
            color: #666;
            text-decoration: none;
            font-size: 13px;
        }
        
        .back-link:hover {
            color: #000;
        }
        
        .info-note {
            font-size: 11px;
            color: #999;
            margin-top: 5px;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Хедер -->
        <!-- Шапка сайта -->
<div class="header">
    <a href="/" class="logo">PLAZA</a>
    <div class="nav-links">
        <a href="/">Главная</a>
        <a href="/catalog">Кроссовки</a>
        <a href="/hunts">Охота</a>
        <a href="#">Бренды</a>
    </div>
    <div class="header-actions">
    <% if (user) { %>
        <a href="/cabinet">Профиль</a>
        <a href="/favorites">❤️ Избранное</a>
        <a href="/cart">🛒 Корзина</a>
        <a href="/logout">Выйти</a>
    <% } else { %>
        <a href="/login">Войти</a>
        <a href="/register">Регистрация</a>
    <% } %>
</div>
</div>
        
        <div class="settings-container">
            <a href="/cabinet" class="back-link">← Назад в кабинет</a>
            
            <% if (success === '1') { %>
                <div class="success-message">Настройки сохранены!</div>
            <% } %>
            
            <% if (success === 'profile_updated') { %>
                <div class="success-message">Профиль обновлен!</div>
            <% } %>
            
            <% if (success === 'password_changed') { %>
                <div class="success-message">Пароль успешно изменен!</div>
            <% } %>
            
            <% if (error === 'wrong_password') { %>
                <div class="error-message">Неверный текущий пароль</div>
            <% } %>
            
            <% if (error === 'password_mismatch') { %>
                <div class="error-message">Новые пароли не совпадают</div>
            <% } %>
            
            <!-- ЛИЧНЫЕ ДАННЫЕ (НОВЫЙ БЛОК) -->
            <div class="settings-card">
                <h2>👤 Личные данные</h2>
                <form method="POST" action="/update-profile">
                    <div class="form-group">
                        <label>Полное имя</label>
                        <input type="text" name="fullname" value="<%= user.fullname || '' %>" placeholder="Иван Иванов">
                    </div>
                    
                    <div class="form-group">
                        <label>Номер телефона</label>
                        <input type="tel" name="phone" value="<%= user.phone || '' %>" placeholder="+7 (999) 123-45-67">
                        <div class="info-note">Для связи по заказам и доставки</div>
                    </div>
                    
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" value="<%= user.email %>" readonly disabled>
                        <div class="info-note">Email нельзя изменить</div>
                    </div>
                    
                    <button type="submit" class="btn">Сохранить изменения</button>
                </form>
            </div>
            
            <!-- Основные настройки (было) -->
            <div class="settings-card">
                <h2>⚙️ Настройки уведомлений</h2>
                <form method="POST" action="/settings">
                    <div class="checkbox-group">
                        <input type="checkbox" name="email_notifications" id="email" <%= settings && settings.email_notifications ? 'checked' : '' %>>
                        <label for="email">Получать уведомления на email</label>
                    </div>
                    
                    <div class="checkbox-group">
                        <input type="checkbox" name="hunt_notifications" id="hunt" <%= settings && settings.hunt_notifications ? 'checked' : '' %>>
                        <label for="hunt">Уведомлять о снижении цен в охоте</label>
                    </div>
                    
                    <div class="form-group">
                        <label>Язык интерфейса</label>
                        <select name="language">
                            <option value="ru" <%= settings && settings.language === 'ru' ? 'selected' : '' %>>Русский</option>
                            <option value="en" <%= settings && settings.language === 'en' ? 'selected' : '' %>>English</option>
                        </select>
                    </div>
                    
                    <button type="submit" class="btn">Сохранить настройки</button>
                </form>
            </div>
            
            <!-- Смена пароля (было) -->
            <div class="settings-card">
                <h2>🔐 Смена пароля</h2>
                <form method="POST" action="/change-password">
                    <div class="form-group">
                        <label>Текущий пароль</label>
                        <input type="password" name="current_password" required>
                    </div>
                    
                    <div class="form-group">
                        <label>Новый пароль</label>
                        <input type="password" name="new_password" required>
                    </div>
                    
                    <div class="form-group">
                        <label>Подтвердите новый пароль</label>
                        <input type="password" name="confirm_password" required>
                    </div>
                    
                    <button type="submit" class="btn">Изменить пароль</button>
                </form>
            </div>
        </div>
        
        <!-- Подвал -->
        <div class="footer">
            <div class="footer-grid">
                <div class="footer-col">
                    <h4>PLAZA</h4>
                    <ul>
                        <li><a href="#">О нас</a></li>
                        <li><a href="#">Контакты</a></li>
                        <li><a href="#">Доставка</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>ПОКУПАТЕЛЯМ</h4>
                    <ul>
                        <li><a href="#">Как заказать</a></li>
                        <li><a href="#">Размерная сетка</a></li>
                        <li><a href="#">Возврат</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>БРЕНДЫ</h4>
                    <ul>
                        <li><a href="#">Nike</a></li>
                        <li><a href="#">Adidas</a></li>
                        <li><a href="#">Li-Ning</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>СВЯЗАТЬСЯ</h4>
                    <ul>
                        <li><a href="#">Telegram</a></li>
                        <li><a href="#">VK</a></li>
                        <li><a href="#">hello@plaza.ru</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                © 2024 PLAZA. Кроссовки со всего мира.
            </div>
        </div>
    </div>
    
    <script>
        const urlParams = new URLSearchParams(window.location.search);
        window.success = urlParams.get('success');
        window.error = urlParams.get('error');
    </script>
    <script src="/js/navigation.js" defer></script>
</body>
</html>