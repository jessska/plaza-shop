<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Избранное | PLAZA</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/main.css">    
    <style>
        .favorites-header {
            margin: 40px 0 20px;
        }
        
        .favorites-header h1 {
            font-size: 24px;
            font-weight: 700;
        }
        
        .favorites-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
            margin: 30px 0;
        }
        
        .favorite-card {
            background: #fff;
            border: 1px solid #eaeaea;
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.3s;
            position: relative;
            display: block;
            text-decoration: none;
            color: inherit;
        }
        
        .favorite-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }
        
        .favorite-image {
            height: 200px;
            background: #f8f8f8;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 48px;
            position: relative;
        }
        
        .favorite-remove {
            position: absolute;
            top: 10px;
            right: 10px;
            background: #fff;
            border: none;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 16px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            z-index: 10;
        }
        
        .favorite-info {
            padding: 15px;
        }
        
        .favorite-brand {
            font-size: 11px;
            font-weight: 600;
            color: #888;
            text-transform: uppercase;
            margin-bottom: 5px;
        }
        
        .favorite-name {
            font-size: 15px;
            font-weight: 700;
            margin-bottom: 10px;
        }
        
        .favorite-price {
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 15px;
        }
        
        .btn-cart {
            background: #000;
            color: #fff;
            border: none;
            padding: 10px;
            border-radius: 8px;
            width: 100%;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            cursor: pointer;
            display: block;
            text-align: center;
            text-decoration: none;
        }
        
        .btn-cart:hover {
            background: #222;
        }
        
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background: #f8f8f8;
            border-radius: 16px;
            margin: 40px 0;
        }
        
        .empty-state p {
            font-size: 16px;
            color: #666;
            margin-bottom: 20px;
        }
        
        .back-link {
            display: inline-block;
            margin-bottom: 20px;
            color: #666;
            text-decoration: none;
            font-size: 13px;
        }
        
        .back-link:hover {
            color: #000;
        }
        
        .success-message {
            background: #e8f5e9;
            border: 1px solid #00b894;
            color: #00b894;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 20px;
        }
        
        .error-message {
            background: #fff0f0;
            border: 1px solid #d63031;
            color: #d63031;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Шапка сайта -->
<div class="header">
    <a href="/" class="logo">PLAZA</a>
    <div class="nav-links">
        <a href="/">Главная</a>
        <a href="/catalog">Кроссовки</a>
        <a href="/hunts">Охота</a>
        <a href="#">Бренды</a>
    </div>
    <div class="header-actions">
    <% if (user) { %>
        <a href="/cabinet">Профиль</a>
        <a href="/favorites">❤️ Избранное</a>
        <a href="/cart">🛒 Корзина</a>
        <a href="/logout">Выйти</a>
    <% } else { %>
        <a href="/login">Войти</a>
        <a href="/register">Регистрация</a>
    <% } %>
</div>
</div>
        
        <a href="/cabinet" class="back-link">← Назад в кабинет</a>
        
        <% if (success === 'added') { %>
            <div class="success-message">Товар добавлен в избранное!</div>
        <% } %>
        
        <% if (success === 'removed') { %>
            <div class="success-message">Товар удален из избранного</div>
        <% } %>
        
        <% if (error === '1') { %>
            <div class="error-message">Произошла ошибка</div>
        <% } %>
        
        <div class="favorites-header">
            <h1>❤️ Избранное</h1>
        </div>
        
        <% if (favorites && favorites.length > 0) { %>
            <div class="favorites-grid">
                <% favorites.forEach(item => { %>
                    <div class="favorite-card" data-id="<%= item.product_id %>">
                        <button class="favorite-remove" onclick="event.preventDefault(); removeFromFavorites(<%= item.product_id %>)">✕</button>
                        <a href="/product/<%= item.product_id %>" class="favorite-image">
                            👟
                        </a>
                        <div class="favorite-info">
                            <div class="favorite-brand"><%= item.brand || 'Бренд' %></div>
                            <div class="favorite-name"><%= item.name %></div>
                            <div class="favorite-price"><%= item.price ? item.price.toLocaleString() + ' ₽' : 'Цена по запросу' %></div>
                            <a href="/product/<%= item.product_id %>" class="btn-cart">Подробнее</a>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <p>В избранном пока ничего нет</p>
                <a href="/catalog" class="btn" style="display: inline-block; padding: 12px 30px; text-decoration: none; background: #000; color: #fff; border-radius: 8px;">Перейти в каталог</a>
            </div>
        <% } %>
        
        <div class="footer">
            <div class="footer-grid">
                <div class="footer-col">
                    <h4>PLAZA</h4>
                    <ul>
                        <li><a href="#">О нас</a></li>
                        <li><a href="#">Контакты</a></li>
                        <li><a href="#">Доставка</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>ПОКУПАТЕЛЯМ</h4>
                    <ul>
                        <li><a href="#">Как заказать</a></li>
                        <li><a href="#">Размерная сетка</a></li>
                        <li><a href="#">Возврат</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>БРЕНДЫ</h4>
                    <ul>
                        <li><a href="#">Nike</a></li>
                        <li><a href="#">Adidas</a></li>
                        <li><a href="#">Li-Ning</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>СВЯЗАТЬСЯ</h4>
                    <ul>
                        <li><a href="#">Telegram</a></li>
                        <li><a href="#">VK</a></li>
                        <li><a href="#">hello@plaza.ru</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                © 2024 PLAZA. Кроссовки со всего мира.
            </div>
        </div>
    </div>
    
    <script src="/js/navigation.js" defer></script>
    <script>
        const urlParams = new URLSearchParams(window.location.search);
        window.success = urlParams.get('success');
        window.error = urlParams.get('error');
        
        function removeFromFavorites(productId) {
            if (confirm('Убрать из избранного?')) {
                fetch(`/favorites/remove/${productId}`, { method: 'POST' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            window.location.href = '/favorites?success=removed';
                        }
                    });
            }
        }
    </script>
</body>
</html>