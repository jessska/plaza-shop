<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Избранное | PLAZA</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    
    <style>
        .favorites-header {
            margin: 40px 0 20px;
        }
        
        .favorites-header h1 {
            font-size: 24px;
            font-weight: 700;
        }
        
        .favorites-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
            margin: 30px 0;
        }
        
        .favorite-card {
            background: var(--bg-primary);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.3s;
            display: block;
            text-decoration: none;
            color: inherit;
        }
        
        .favorite-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow);
            border-color: var(--accent);
        }
        
        .favorite-image {
            width: 100%;
            aspect-ratio: 1 / 1;
            background: var(--bg-secondary);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }
        
        .favorite-image img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 8px;
            box-sizing: border-box;
        }
        
        .favorite-remove {
            position: absolute;
            top: 10px;
            right: 10px;
            background: #fff;
            border: none;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 16px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            z-index: 10;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .favorite-remove:hover {
            background: #f0f0f0;
        }
        
        .favorite-info {
            padding: 15px;
        }
        
        .favorite-brand {
            font-size: 11px;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            margin-bottom: 5px;
        }
        
        .favorite-name {
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 8px;
            color: var(--text-primary);
            line-height: 1.3;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            min-height: 36px;
        }
        
        .favorite-price {
            font-size: 14px;
            font-weight: 700;
            margin-bottom: 12px;
            color: var(--accent);
        }
        
        .btn-cart {
            background: var(--accent);
            color: #fff;
            border: none;
            padding: 10px;
            border-radius: 8px;
            width: 100%;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            cursor: pointer;
            display: block;
            text-align: center;
            text-decoration: none;
            transition: background 0.2s;
        }
        
        .btn-cart:hover {
            background: var(--accent-hover);
        }
        
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background: var(--bg-secondary);
            border-radius: 16px;
            margin: 40px 0;
        }
        
        .empty-state p {
            font-size: 16px;
            color: var(--text-muted);
            margin-bottom: 20px;
        }
        
        .empty-state .btn {
            display: inline-block;
            padding: 12px 30px;
            background: var(--accent);
            color: white;
            text-decoration: none;
            border-radius: 8px;
        }
        
        .back-link {
            display: inline-block;
            margin-bottom: 20px;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 13px;
        }
        
        .back-link:hover {
            color: var(--accent);
        }
        
        @media (max-width: 768px) {
            .favorites-grid {
                grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Шапка -->
        <div class="header">
            <a href="/" class="logo">PLAZA</a>
            <div class="nav-links">
                <a href="/">Главная</a>
                <a href="/catalog">Кроссовки</a>
                <a href="/hunts">Охота</a>
                <a href="#">Бренды</a>
            </div>
            <div class="header-actions">
                <% if (user) { %>
                    <a href="/cabinet">Профиль</a>
                    <a href="/favorites">❤️ Избранное</a>
                    <a href="/cart">🛒 Корзина</a>
                    <a href="/logout">Выйти</a>
                <% } else { %>
                    <a href="/login">Войти</a>
                    <a href="/register">Регистрация</a>
                <% } %>
            </div>
        </div>

        <a href="/cabinet" class="back-link">← Назад в кабинет</a>

        <div class="favorites-header">
            <h1>❤️ Избранное</h1>
        </div>

        <% if (favorites && favorites.length > 0) { %>
            <div class="favorites-grid">
                <% favorites.forEach(item => { %>
                    <div class="favorite-card" data-id="<%= item.product_id %>">
                        <div class="favorite-image">
                            <% if (item.image) { %>
                                <img src="<%= item.image %>" alt="<%= item.name %>">
                            <% } else { %>
                                👟
                            <% } %>
                            <button class="favorite-remove" onclick="event.preventDefault(); removeFromFavorites(<%= item.product_id %>)">✕</button>
                        </div>
                        <div class="favorite-info">
                            <div class="favorite-brand"><%= item.brand || 'Бренд' %></div>
                            <div class="favorite-name"><%= item.name.length > 40 ? item.name.substring(0,40) + '...' : item.name %></div>
                            <div class="favorite-price"><%= item.price ? item.price.toLocaleString() + ' ₽' : 'Цена по запросу' %></div>
                            <a href="/product/<%= item.product_id %>" class="btn-cart">Подробнее</a>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <p>В избранном пока ничего нет</p>
                <a href="/catalog" class="btn">Перейти в каталог</a>
            </div>
        <% } %>

        <!-- Подвал -->
        <div class="footer">
            <div class="footer-grid">
                <div class="footer-col">
                    <h4>PLAZA</h4>
                    <ul>
                        <li><a href="#">О нас</a></li>
                        <li><a href="#">Контакты</a></li>
                        <li><a href="#">Доставка</a></li>
                        <li><a href="#">Оплата</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>ПОКУПАТЕЛЯМ</h4>
                    <ul>
                        <li><a href="#">Как заказать</a></li>
                        <li><a href="#">Размерная сетка</a></li>
                        <li><a href="#">Возврат</a></li>
                        <li><a href="#">FAQ</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>БРЕНДЫ</h4>
                    <ul>
                        <li><a href="#">Nike</a></li>
                        <li><a href="#">Adidas</a></li>
                        <li><a href="#">Li-Ning</a></li>
                        <li><a href="#">New Balance</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>СВЯЗАТЬСЯ</h4>
                    <ul>
                        <li><a href="#">Telegram</a></li>
                        <li><a href="#">VK</a></li>
                        <li><a href="#">hello@plaza.ru</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                © 2024 PLAZA. Кроссовки со всего мира.
            </div>
        </div>
    </div>

    <script>
        function removeFromFavorites(productId) {
            if (confirm('Убрать из избранного?')) {
                fetch(`/favorites/remove/${productId}`, { method: 'POST' })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            location.reload();
                        }
                    })
                    .catch(err => {
                        console.error('Ошибка:', err);
                        alert('Произошла ошибка');
                    });
            }
        }
    </script>
</body>
</html>