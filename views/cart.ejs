<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Корзина | PLAZA</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/main.css">    
    <style>
        .cart-container {
            max-width: 1000px;
            margin: 40px auto;
        }
        
        .cart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }
        
        .cart-header h1 {
            font-size: 24px;
            font-weight: 700;
        }
        
        .cart-empty {
            text-align: center;
            padding: 60px 20px;
            background: #f8f8f8;
            border-radius: 16px;
        }
        
        .cart-empty p {
            font-size: 16px;
            color: #666;
            margin-bottom: 20px;
        }
        
        .cart-empty .btn {
            display: inline-block;
            padding: 12px 30px;
            background: #000;
            color: #fff;
            text-decoration: none;
            border-radius: 8px;
        }
        
        .cart-items {
            background: #fff;
            border: 1px solid #eaeaea;
            border-radius: 16px;
            overflow: hidden;
        }
        
        .cart-item {
            display: grid;
            grid-template-columns: 100px 1fr auto auto auto;
            gap: 20px;
            align-items: center;
            padding: 20px;
            border-bottom: 1px solid #f0f0f0;
        }
        
        .cart-item:last-child {
            border-bottom: none;
        }
        
        .cart-item-image {
            width: 100px;
            height: 100px;
            background: #f5f5f5;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
        }
        
        .cart-item-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 8px;
        }
        
        .cart-item-info h3 {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 5px;
        }
        
        .cart-item-brand {
            font-size: 12px;
            color: #666;
            margin-bottom: 5px;
        }
        
        .cart-item-size {
            font-size: 12px;
            color: #999;
        }
        
        .cart-item-price {
            font-weight: 700;
            font-size: 16px;
        }
        
        .cart-item-quantity {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .quantity-btn {
            width: 30px;
            height: 30px;
            border: 1px solid #eaeaea;
            background: #fff;
            border-radius: 4px;
            cursor: pointer;
            font-size: 16px;
        }
        
        .quantity-btn:hover {
            background: #f5f5f5;
        }
        
        .quantity-value {
            min-width: 30px;
            text-align: center;
        }
        
        .cart-item-total {
            font-weight: 700;
            font-size: 18px;
            min-width: 100px;
            text-align: right;
        }
        
        .cart-item-remove {
            color: #d63031;
            cursor: pointer;
            font-size: 20px;
            padding: 5px;
        }
        
        .cart-footer {
            margin-top: 30px;
            padding: 20px;
            background: #f8f8f8;
            border-radius: 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .cart-total {
            font-size: 20px;
            font-weight: 700;
        }
        
        .cart-total span {
            color: #000;
            margin-left: 10px;
        }
        
        .cart-actions {
            display: flex;
            gap: 15px;
        }
        
        .btn-primary, .btn-secondary {
            padding: 12px 30px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
        }
        
        .btn-primary {
            background: #000;
            color: #fff;
        }
        
        .btn-primary:hover {
            background: #222;
        }
        
        .btn-secondary {
            background: #fff;
            border: 1px solid #000;
            color: #000;
        }
        
        .btn-secondary:hover {
            background: #f5f5f5;
        }
        
        @media (max-width: 768px) {
            .cart-item {
                grid-template-columns: 80px 1fr;
                gap: 15px;
            }
            
            .cart-item-price, .cart-item-quantity, .cart-item-total {
                grid-column: 2;
            }
            
            .cart-item-remove {
                position: absolute;
                top: 10px;
                right: 10px;
            }
            
            .cart-footer {
                flex-direction: column;
                gap: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Шапка -->
        <div class="header">
            <a href="/" class="logo">PLAZA</a>
            <div class="nav-links">
                <a href="/">Главная</a>
                <a href="/catalog">Кроссовки</a>
                <a href="/hunts">Охота</a>
                <a href="#">Бренды</a>
            </div>
            <div class="header-actions">
    <% if (user) { %>
        <a href="/cabinet">Профиль</a>
        <a href="/favorites">❤️ Избранное</a>
        <a href="/cart">🛒 Корзина</a>
        <a href="/logout">Выйти</a>
    <% } else { %>
        <a href="/login">Войти</a>
        <a href="/register">Регистрация</a>
    <% } %>
</div>
        </div>

        <!-- Корзина -->
        <div class="cart-container">
            <div class="cart-header">
                <h1>🛒 Корзина</h1>
                <% if (cartItems && cartItems.length > 0) { %>
                    <form method="POST" action="/cart/clear" onsubmit="return confirm('Очистить корзину?')">
                        <button type="submit" class="btn-secondary" style="padding: 8px 15px;">Очистить корзину</button>
                    </form>
                <% } %>
            </div>

            <% if (cartItems && cartItems.length > 0) { %>
                <div class="cart-items">
                    <% cartItems.forEach(item => { %>
                        <div class="cart-item" data-id="<%= item.id %>">
                            <div class="cart-item-image">
                                <% if (item.image && item.image.startsWith('http')) { %>
                                    <img src="<%= item.image %>" alt="<%= item.name %>">
                                <% } else { %>
                                    👟
                                <% } %>
                            </div>
                            
                            <div class="cart-item-info">
                                <h3><%= item.name %></h3>
                                <div class="cart-item-brand"><%= item.brand %></div>
                                <% if (item.size) { %>
                                    <div class="cart-item-size">Размер: <%= item.size %></div>
                                <% } %>
                            </div>
                            
                            <div class="cart-item-price">
                                <%= item.price.toLocaleString() %> ₽
                            </div>
                            
                            <div class="cart-item-quantity">
                                <button class="quantity-btn" onclick="updateQuantity(<%= item.id %>, <%= item.quantity - 1 %>)">−</button>
                                <span class="quantity-value"><%= item.quantity %></span>
                                <button class="quantity-btn" onclick="updateQuantity(<%= item.id %>, <%= item.quantity + 1 %>)">+</button>
                            </div>
                            
                            <div class="cart-item-total">
                                <%= (item.price * item.quantity).toLocaleString() %> ₽
                            </div>
                            
                            <div class="cart-item-remove" onclick="removeItem(<%= item.id %>)">✕</div>
                        </div>
                    <% }) %>
                </div>

                <div class="cart-footer">
                    <div class="cart-total">
                        Итого: <span><%= total.toLocaleString() %> ₽</span>
                    </div>
                    <div class="cart-actions">
                        <a href="/catalog" class="btn-secondary">Продолжить покупки</a>
                        <button class="btn-primary" onclick="alert('Оформление заказа в разработке')">Оформить заказ</button>
                    </div>
                </div>

            <% } else { %>
                <div class="cart-empty">
                    <p>🛒 В корзине пока пусто</p>
                    <a href="/catalog" class="btn">Перейти в каталог</a>
                </div>
            <% } %>
        </div>

        <!-- Подвал -->
        <div class="footer">
            <div class="footer-grid">
                <div class="footer-col">
                    <h4>PLAZA</h4>
                    <ul>
                        <li><a href="#">О нас</a></li>
                        <li><a href="#">Контакты</a></li>
                        <li><a href="#">Доставка</a></li>
                        <li><a href="#">Оплата</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>ПОКУПАТЕЛЯМ</h4>
                    <ul>
                        <li><a href="#">Как заказать</a></li>
                        <li><a href="#">Размерная сетка</a></li>
                        <li><a href="#">Возврат</a></li>
                        <li><a href="#">FAQ</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>БРЕНДЫ</h4>
                    <ul>
                        <li><a href="#">Nike</a></li>
                        <li><a href="#">Adidas</a></li>
                        <li><a href="#">Li-Ning</a></li>
                        <li><a href="#">New Balance</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>СВЯЗАТЬСЯ</h4>
                    <ul>
                        <li><a href="#">Telegram</a></li>
                        <li><a href="#">VK</a></li>
                        <li><a href="#">hello@plaza.ru</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                © 2024 PLAZA. Кроссовки со всего мира.
            </div>
        </div>
    </div>

    <script>
        function updateQuantity(itemId, newQuantity) {
            if (newQuantity < 1) {
                removeItem(itemId);
                return;
            }
            
            fetch('/cart/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ itemId, quantity: newQuantity })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                }
            });
        }
        
        function removeItem(itemId) {
            if (confirm('Удалить товар из корзины?')) {
                fetch(`/cart/remove/${itemId}`, { method: 'POST' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    }
                });
            }
        }
    </script>
</body>
</html>