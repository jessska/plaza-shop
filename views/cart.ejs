<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Корзина | PLAZA</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <style>
        .cart-container { max-width: 1000px; margin: 40px auto; }
        .cart-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        .cart-header h1 { font-size: 24px; font-weight: 700; }
        .cart-empty { text-align: center; padding: 60px 20px; background: var(--bg-secondary); border-radius: 16px; }
        .cart-empty p { font-size: 16px; color: var(--text-muted); margin-bottom: 20px; }
        .cart-empty .btn { display: inline-block; padding: 12px 30px; background: var(--accent); color: white; text-decoration: none; border-radius: 8px; }
        .cart-items { background: var(--bg-primary); border: 1px solid var(--border-color); border-radius: 16px; overflow: hidden; }
        .cart-item { display: grid; grid-template-columns: 100px 1fr auto auto auto; gap: 20px; align-items: center; padding: 20px; border-bottom: 1px solid var(--border-color); }
        .cart-item:last-child { border-bottom: none; }
        .cart-item-image { width: 100px; height: 100px; background: var(--bg-secondary); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 40px; overflow: hidden; }
        .cart-item-image img { width: 100%; height: 100%; object-fit: cover; }
        .cart-item-info h3 { font-size: 16px; font-weight: 600; margin-bottom: 5px; color: var(--text-primary); }
        .cart-item-brand { font-size: 12px; color: var(--text-muted); }
        .cart-item-price { font-weight: 700; font-size: 16px; color: var(--accent); }
        .cart-item-quantity { display: flex; align-items: center; gap: 10px; }
        .quantity-btn { width: 30px; height: 30px; border: 1px solid var(--border-color); background: var(--bg-primary); border-radius: 4px; cursor: pointer; color: var(--text-primary); }
        .quantity-btn:hover { background: var(--bg-secondary); }
        .cart-item-total { font-weight: 700; font-size: 18px; color: var(--accent); }
        .cart-item-remove { color: #d63031; cursor: pointer; font-size: 20px; }
        .cart-footer { margin-top: 30px; padding: 20px; background: var(--bg-secondary); border-radius: 16px; display: flex; justify-content: space-between; align-items: center; }
        .cart-total { font-size: 20px; font-weight: 700; color: var(--text-primary); }
        .cart-total span { color: var(--accent); margin-left: 10px; }
        .btn-primary { background: var(--accent); color: white; border: none; padding: 12px 30px; border-radius: 8px; font-weight: 600; cursor: pointer; }
        .btn-secondary { background: var(--bg-primary); border: 1px solid var(--border-color); color: var(--text-primary); padding: 12px 30px; border-radius: 8px; font-weight: 600; cursor: pointer; text-decoration: none; display: inline-block; }
    </style>
</head>
<body>
    <div class="container">
        <!-- ШАПКА -->
        <div class="header">
            <a href="/" class="logo">PLAZA</a>
            <div class="nav-links">
                <a href="/">Главная</a>
                <a href="/catalog">Кроссовки</a>
                <a href="/hunts">Охота</a>
                <a href="#">Бренды</a>
            </div>
            <div class="header-actions">
                <% if (user) { %>
                    <a href="/cabinet">Профиль</a>
                    <a href="/favorites">❤️ Избранное</a>
                    <a href="/cart">🛒 Корзина</a>
                    <a href="/logout">Выйти</a>
                <% } else { %>
                    <a href="/login">Войти</a>
                    <a href="/register">Регистрация</a>
                <% } %>
            </div>
        </div>

        <div class="cart-container">
            <div class="cart-header">
                <h1>🛒 Корзина</h1>
                <% if (cartItems && cartItems.length > 0) { %>
                    <form method="POST" action="/cart/clear" onsubmit="return confirm('Очистить корзину?')">
                        <button type="submit" class="btn-secondary" style="padding: 8px 15px;">Очистить</button>
                    </form>
                <% } %>
            </div>

            <% if (cartItems && cartItems.length > 0) { %>
                <div class="cart-items">
                    <% cartItems.forEach(item => { %>
                        <div class="cart-item" data-id="<%= item.id %>">
                            <div class="cart-item-image">
                                <% if (item.image && item.image.startsWith('http')) { %>
                                    <img src="<%= item.image %>" alt="<%= item.name %>">
                                <% } else { %>
                                    👟
                                <% } %>
                            </div>
                            
                            <div class="cart-item-info">
                                <h3><%= item.name %></h3>
                                <div class="cart-item-brand"><%= item.brand %></div>
                                <% if (item.size) { %>
                                    <div style="font-size: 11px; color: var(--text-muted);">Размер: <%= item.size %></div>
                                <% } %>
                            </div>
                            
                            <div class="cart-item-price">
                                <%= item.price.toLocaleString() %> ₽
                            </div>
                            
                            <div class="cart-item-quantity">
                                <button class="quantity-btn" onclick="updateQuantity(<%= item.id %>, <%= item.quantity - 1 %>)">−</button>
                                <span><%= item.quantity %></span>
                                <button class="quantity-btn" onclick="updateQuantity(<%= item.id %>, <%= item.quantity + 1 %>)">+</button>
                            </div>
                            
                            <div class="cart-item-total">
                                <%= (item.price * item.quantity).toLocaleString() %> ₽
                            </div>
                            
                            <div class="cart-item-remove" onclick="removeItem(<%= item.id %>)">✕</div>
                        </div>
                    <% }) %>
                </div>

                <div class="cart-footer">
                    <div class="cart-total">
                        Итого: <span><%= total.toLocaleString() %> ₽</span>
                    </div>
                    <div style="display: flex; gap: 15px;">
                        <a href="/catalog" class="btn-secondary">Продолжить</a>
                        <button class="btn-primary" onclick="alert('Оформление заказа в разработке')">Оформить</button>
                    </div>
                </div>

            <% } else { %>
                <div class="cart-empty">
                    <p>🛒 В корзине пока пусто</p>
                    <a href="/catalog" class="btn">Перейти в каталог</a>
                </div>
            <% } %>
        </div>

        <!-- ПОДВАЛ -->
        <div class="footer">
            <div class="footer-grid">
                <div class="footer-col">
                    <h4>PLAZA</h4>
                    <ul>
                        <li><a href="#">О нас</a></li>
                        <li><a href="#">Контакты</a></li>
                        <li><a href="#">Доставка</a></li>
                        <li><a href="#">Оплата</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>ПОКУПАТЕЛЯМ</h4>
                    <ul>
                        <li><a href="#">Как заказать</a></li>
                        <li><a href="#">Размерная сетка</a></li>
                        <li><a href="#">Возврат</a></li>
                        <li><a href="#">FAQ</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>БРЕНДЫ</h4>
                    <ul>
                        <li><a href="#">Nike</a></li>
                        <li><a href="#">Adidas</a></li>
                        <li><a href="#">Li-Ning</a></li>
                        <li><a href="#">New Balance</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>СВЯЗАТЬСЯ</h4>
                    <ul>
                        <li><a href="#">Telegram</a></li>
                        <li><a href="#">VK</a></li>
                        <li><a href="#">hello@plaza.ru</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                © 2024 PLAZA. Кроссовки со всего мира.
            </div>
        </div>
    </div>

    <script>
        function updateQuantity(itemId, newQuantity) {
            if (newQuantity < 1) {
                removeItem(itemId);
                return;
            }
            fetch('/cart/update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ itemId, quantity: newQuantity })
            })
            .then(res => res.json())
            .then(data => { if (data.success) location.reload(); });
        }
        
        function removeItem(itemId) {
            if (confirm('Удалить товар из корзины?')) {
                fetch(`/cart/remove/${itemId}`, { method: 'POST' })
                .then(res => res.json())
                .then(data => { if (data.success) location.reload(); });
            }
        }
    </script>
</body>
</html>