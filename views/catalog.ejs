<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Каталог кроссовок | PLAZA</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    
    <style>
        /* Пагинация как раньше */
        .pagination {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin: 40px 0;
        }
        
        .pagination a, .pagination span {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 36px;
            height: 36px;
            padding: 0 8px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            text-decoration: none;
            color: var(--text-muted);
            font-size: 13px;
            transition: all 0.2s;
        }
        
        .pagination a:hover {
            background: var(--accent);
            color: white;
            border-color: var(--accent);
        }
        
        .pagination .active {
            background: var(--accent);
            color: white;
            border-color: var(--accent);
        }
        
        .pagination .disabled {
            opacity: 0.5;
            pointer-events: none;
        }
        
        /* Заголовок каталога */
        .catalog-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding: 15px 0;
            border-bottom: 1px solid var(--border-color);
        }
        
        .product-count {
            font-size: 14px;
            color: var(--text-muted);
        }
        
        .product-count span {
            font-weight: 700;
            color: var(--accent);
        }
        
        .sort {
            display: flex;
            gap: 20px;
        }
        
        .sort a {
            text-decoration: none;
            color: var(--text-muted);
            font-size: 13px;
            transition: color 0.2s;
        }
        
        .sort a:hover {
            color: var(--accent);
        }
        
        /* Фильтры без sticky */
        .filters {
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 25px;
            height: fit-content;
        }
        
        .filter-section {
            margin-bottom: 30px;
        }
        
        .filter-section h3 {
            font-size: 13px;
            font-weight: 700;
            color: var(--text-primary);
            text-transform: uppercase;
            margin-bottom: 15px;
            letter-spacing: 0.5px;
        }
        
        .filter-list {
            list-style: none;
        }
        
        .filter-list li {
            margin-bottom: 12px;
        }
        
        .filter-list a {
            text-decoration: none;
            color: var(--text-muted);
            font-size: 13px;
            font-weight: 500;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: color 0.2s;
        }
        
        .filter-list a:hover {
            color: var(--accent);
        }
        
        .filter-list .count {
            color: var(--text-muted);
            font-size: 11px;
            background: var(--bg-primary);
            padding: 2px 6px;
            border-radius: 4px;
        }
        
        .hunt-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 6px;
        }
        
        .hunt-dot.easy { background: var(--hunt-easy); }
        .hunt-dot.medium { background: var(--hunt-medium); }
        .hunt-dot.hard { background: var(--hunt-hard); }
    </style>
</head>
<body>
    <div class="container">
        <!-- Шапка -->
        <div class="header">
            <a href="/" class="logo">PLAZA</a>
            <div class="nav-links">
                <a href="/">Главная</a>
                <a href="/catalog">Кроссовки</a>
                <a href="/hunts">Охота</a>
                <a href="#">Бренды</a>
            </div>
            <div class="header-actions">
                <% if (user) { %>
                    <a href="/cabinet">Профиль</a>
                    <a href="/favorites">❤️ Избранное</a>
                    <a href="/cart">🛒 Корзина</a>
                    <a href="/logout">Выйти</a>
                <% } else { %>
                    <a href="/login">Войти</a>
                    <a href="/register">Регистрация</a>
                <% } %>
            </div>
        </div>

        <!-- Каталог -->
        <div class="catalog-layout" style="display: grid; grid-template-columns: 260px 1fr; gap: 30px;">
            <!-- Фильтры слева -->
            <div class="filters">
                <div class="filter-section">
                    <h3>КАТЕГОРИЯ</h3>
                    <ul class="filter-list">
                        <li><a href="#">Все товары <span class="count"><%= totalProducts %></span></a></li>
                        <li><a href="#">Кроссовки <span class="count"><%= sneakersCount %></span></a></li>
                    </ul>
                </div>

                <div class="filter-section">
                    <h3>БРЕНДЫ</h3>
                    <ul class="filter-list">
                        <li><a href="#">Nike <span class="count">28</span></a></li>
                        <li><a href="#">Adidas <span class="count">24</span></a></li>
                        <li><a href="#">Jordan <span class="count">15</span></a></li>
                        <li><a href="#">New Balance <span class="count">12</span></a></li>
                        <li><a href="#">ASICS <span class="count">8</span></a></li>
                    </ul>
                </div>

                <div class="filter-section">
                    <h3>УРОВЕНЬ ОХОТЫ</h3>
                    <ul class="filter-list">
                        <li>
                            <a href="#">
                                <span>
                                    <span class="hunt-dot easy"></span> Easy Hunt
                                </span>
                                <span class="count"><%= easyCount %></span>
                            </a>
                        </li>
                        <li>
                            <a href="#">
                                <span>
                                    <span class="hunt-dot medium"></span> Medium Hunt
                                </span>
                                <span class="count"><%= mediumCount %></span>
                            </a>
                        </li>
                        <li>
                            <a href="#">
                                <span>
                                    <span class="hunt-dot hard"></span> Hard Hunt
                                </span>
                                <span class="count"><%= hardCount %></span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Товары -->
            <div>
                <!-- Заголовок -->
                <div class="catalog-header">
                    <div class="product-count">
                        Страница <span><%= currentPage %></span> из <span><%= totalPages %></span>
                    </div>
                    <div class="sort">
                        <span style="color: var(--text-muted);">Сортировка:</span>
                        <a href="#">По умолчанию</a>
                        <a href="#">Цена ↑</a>
                        <a href="#">Цена ↓</a>
                    </div>
                </div>

                <!-- Сетка товаров -->
                <div class="products-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">
                    <% if (products && products.length > 0) { %>
                        <% products.forEach(product => { %>
                            <a href="/product/<%= product.id %>" class="product-card">
                                <div class="product-image">
                                    <% if (product.image && product.image.startsWith('http')) { %>
                                        <img src="<%= product.image %>" alt="<%= product.name %>">
                                    <% } else { %>
                                        👟
                                    <% } %>
                                </div>
                                <div class="product-brand"><%= product.brand || 'Бренд' %></div>
                                <div class="product-name"><%= product.name.length > 40 ? product.name.substring(0,40) + '...' : product.name %></div>
                                <div class="product-price-row">
                                    <span class="product-price"><%= product.price.toLocaleString() %> ₽</span>
                                    <% if (product.old_price) { %>
                                        <span class="product-oldprice"><%= product.old_price.toLocaleString() %> ₽</span>
                                    <% } %>
                                </div>
                                <div class="product-sizes">
                                    <% 
                                        let sizes = [];
                                        try {
                                            sizes = JSON.parse(product.sizes);
                                        } catch(e) {
                                            sizes = ['40','41','42','43','44'];
                                        }
                                        sizes.slice(0,4).forEach(size => { 
                                    %>
                                        <span><%= size %></span>
                                    <% }) %>
                                </div>
                            </a>
                        <% }) %>
                    <% } else { %>
                        <div style="grid-column: 1/-1; text-align: center; padding: 60px;">
                            <p>😕 Товаров пока нет</p>
                        </div>
                    <% } %>
                </div>

                <!-- Пагинация -->
                <% if (totalPages > 1) { %>
                    <div class="pagination">
                        <% if (currentPage > 1) { %>
                            <a href="/catalog?page=<%= currentPage - 1 %>">←</a>
                        <% } else { %>
                            <span class="disabled">←</span>
                        <% } %>
                        
                        <% for (let i = 1; i <= totalPages; i++) { %>
                            <% if (i === currentPage) { %>
                                <span class="active"><%= i %></span>
                            <% } else if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) { %>
                                <a href="/catalog?page=<%= i %>"><%= i %></a>
                            <% } else if (i === currentPage - 3 || i === currentPage + 3) { %>
                                <span>...</span>
                            <% } %>
                        <% } %>
                        
                        <% if (currentPage < totalPages) { %>
                            <a href="/catalog?page=<%= currentPage + 1 %>">→</a>
                        <% } else { %>
                            <span class="disabled">→</span>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Подвал -->
        <div class="footer">
            <div class="footer-grid">
                <div class="footer-col">
                    <h4>PLAZA</h4>
                    <ul>
                        <li><a href="#">О нас</a></li>
                        <li><a href="#">Контакты</a></li>
                        <li><a href="#">Доставка</a></li>
                        <li><a href="#">Оплата</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>ПОКУПАТЕЛЯМ</h4>
                    <ul>
                        <li><a href="#">Как заказать</a></li>
                        <li><a href="#">Размерная сетка</a></li>
                        <li><a href="#">Возврат</a></li>
                        <li><a href="#">FAQ</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>БРЕНДЫ</h4>
                    <ul>
                        <li><a href="#">Nike</a></li>
                        <li><a href="#">Adidas</a></li>
                        <li><a href="#">Li-Ning</a></li>
                        <li><a href="#">New Balance</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>СВЯЗАТЬСЯ</h4>
                    <ul>
                        <li><a href="#">Telegram</a></li>
                        <li><a href="#">VK</a></li>
                        <li><a href="#">hello@plaza.ru</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                © 2024 PLAZA. Кроссовки со всего мира.
            </div>
        </div>
    </div>
</body>
</html>