<!DOCTYPE html>
<html lang="ru">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Регистрация | PLAZA</title>
    
    <!-- Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap" rel="stylesheet">
    
    <!-- Глобальные стили -->
<link rel="stylesheet" href="/css/main.css">    
    <style>
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            padding: 20px;
            background: #f8f8f8;
        }
        
        .register-container {
            max-width: 400px;
            width: 100%;
            background: #fff;
            border: 1px solid #eaeaea;
            border-radius: 16px;
            padding: 40px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }
        
        .logo {
            font-size: 28px;
            font-weight: 700;
            text-align: center;
            margin-bottom: 10px;
            letter-spacing: -0.5px;
        }
        
        .title {
            font-size: 24px;
            font-weight: 700;
            text-align: center;
            margin-bottom: 30px;
            letter-spacing: -0.5px;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        
        label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #666;
        }
        
        input {
            width: 100%;
            padding: 12px;
            border: 1px solid #eaeaea;
            border-radius: 8px;
            font-size: 14px;
            transition: border-color 0.2s;
        }
        
        input:focus {
            outline: none;
            border-color: #000;
        }
        
        .btn {
            width: 100%;
            padding: 14px;
            background: #000;
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            cursor: pointer;
            margin-top: 10px;
        }
        
        .btn:hover {
            background: #222;
        }
        
        .error {
            background: #fff0f0;
            border: 1px solid #ff6b6b;
            color: #d63031;
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 13px;
            font-weight: 500;
            text-align: center;
        }
        
        .footer-link {
            text-align: center;
            margin-top: 20px;
            font-size: 13px;
            color: #666;
        }
        
        .footer-link a {
            color: #000;
            text-decoration: none;
            font-weight: 600;
        }
        
        .footer-link a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="register-container">
        <div class="logo">PLAZA</div>
        <div class="title">Регистрация</div>
        
        <% if (error) { %>
            <div class="error"><%= error %></div>
        <% } %>
        
        <form method="POST" action="/register">
            <div class="form-group">
                <label>Имя пользователя</label>
                <input type="text" name="username" required placeholder="sneakerhead">
            </div>
            
            <div class="form-group">
    <label>Полное имя</label>
    <input type="text" name="fullname" required placeholder="Иван Иванов">
</div>

<!-- ДОБАВЬ ЭТОТ БЛОК -->
<div class="form-group">
    <label>Номер телефона</label>
    <input type="tel" name="phone" required placeholder="+7 (999) 123-45-67">
</div>

<div class="form-group">
    <label>Email</label>
    <input type="email" name="email" required placeholder="ivan@example.com">
</div>
            
            <div class="form-group">
                <label>Пароль</label>
                <input type="password" name="password" required placeholder="••••••••">
            </div>
            
            <button type="submit" class="btn">Зарегистрироваться</button>
        </form>
        
        <div class="footer-link">
            Уже есть аккаунт? <a href="/login">Войти</a>
        </div>
    </div>
    <script src="/js/navigation.js" defer></script>
</body>
</html>